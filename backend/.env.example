# --- Kickr backend (build.md §10) ---
# Everything runs in DEMO_MODE without any external credentials.

# Postgres (Supabase) in prod; SQLite locally for zero-setup demo.
DATABASE_URL=sqlite:///./kickr.db

# TxLINE — leave blank in demo mode. Must match the network the credentials
# below were activated on (chain/scripts/activate-txline.ts prints both).
#   mainnet -> https://txline.txodds.com
#   devnet  -> https://txline-dev.txodds.com
TXLINE_API_ORIGIN=https://txline.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=

# Privy — leave blank to use the dev sign-in (handle-based token `dev:<handle>`).
# NOTE: if this is set it wins outright — the dev token is rejected even in demo mode.
PRIVY_APP_ID=

# Telegram bot (build.md Part 2) from @BotFather. Blank disables the bot; the
# Brain runs either way and never blocks on Telegram.
TELEGRAM_BOT_TOKEN=

# Solana devnet receipts — leave blank to no-op receipts in demo.
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_KEYPAIR=

# Demo / replay (§9): true replays fixtures/demo_match.jsonl, no TxLINE needed.
DEMO_MODE=true

# Guards POST /api/admin/demo/restart.
ADMIN_KEY=kickr-dev-admin

# Pricing overround (§3.4).
MARGIN=0.05
