# --- Kickr chain (Solana devnet receipt committer) ---

# Devnet RPC.
SOLANA_RPC=https://api.devnet.solana.com

# Base58 secret key for the Kickr receipt wallet. The activate-txline script
# creates one under .keys/ and airdrops devnet SOL if this is unset.
SOLANA_KEYPAIR=

# TxLINE devnet access (populated by scripts/activate-txline.ts).
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
