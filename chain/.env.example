# --- Kickr chain ---

# Which TxLINE network to subscribe on: devnet | mainnet.
# Selects the API origin, Solana RPC, program ID, TxL mint and service level
# together — TxLINE rejects activation if these are mixed across networks.
TXLINE_NETWORK=devnet

# Optional overrides. Leave blank to use the network's defaults:
#   mainnet -> https://txline.txodds.com   + https://api.mainnet-beta.solana.com
#   devnet  -> https://txline-dev.txodds.com + https://api.devnet.solana.com
TXLINE_API_ORIGIN=
TXLINE_SOLANA_RPC=

# Service level. Default is 12 on mainnet (World Cup, real-time, 0 TxL) and 1 on
# devnet. Do NOT use 1 on mainnet: same free bundle, but 60s-delayed, which
# breaks in-play settlement.
TXLINE_SERVICE_LEVEL=

# --- Solana receipts (separate from TxLINE, stays on devnet) ---

# RPC for the receipt committer only. Kept apart from TXLINE_SOLANA_RPC so
# subscribing on mainnet doesn't move receipts onto mainnet.
SOLANA_RPC=https://api.devnet.solana.com

# Base58 secret key for the Kickr receipt wallet. The activate-txline script
# creates one under .keys/ and airdrops devnet SOL if this is unset.
SOLANA_KEYPAIR=
